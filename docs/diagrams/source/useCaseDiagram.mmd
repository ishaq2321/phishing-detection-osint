usecaseDiagram
    actor User
    
    rectangle "PhishGuard System" {
        usecase "Analyze URL" as UC1
        usecase "Analyze Email" as UC2
        usecase "Analyze Free Text" as UC3
        usecase "View History" as UC4
        usecase "Clear History" as UC5
        usecase "View Results Details (SHAP)" as UC6
    }
    
    User --> UC1
    User --> UC2
    User --> UC3
    User --> UC4
    User --> UC5
    UC1 ..> UC6 : <<include>>
    UC2 ..> UC6 : <<include>>
